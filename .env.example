# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────
# Option A: OpenAI API (recommended — GPT-4o-mini)
# Overrides HF_TOKEN if both are set
OPENAI_API_KEY=sk-proj-your_openai_key_here

# Option B: HuggingFace token — enables LLM inference via HF router
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# LLM API base URL (only needed for HuggingFace; ignored when OPENAI_API_KEY is set)
# Default: HuggingFace router
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for triage predictions
# OpenAI default:      gpt-4o-mini
# HuggingFace default: meta-llama/Llama-3.1-8B-Instruct
MODEL_NAME=gpt-4o-mini
